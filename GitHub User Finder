import tkinter as tk
from tkinter import ttk, messagebox
import requests
import json
import os
from datetime import datetime

class GitHubUserFinder:
    def __init__(self, root):
        self.root = root
        self.root.title("GitHub User Finder")
        self.root.geometry("700x600")
        self.root.resizable(False, False)

        # Файл для избранных
        self.favorites_file = "favorites.json"
        self.favorites = self.load_favorites()

        # Виджеты
        self.create_widgets()

    def create_widgets(self):
        # Поле поиска
        tk.Label(self.root, text="Введите имя пользователя GitHub:", font=("Arial", 12)).pack(pady=(20, 5))
        self.search_entry = tk.Entry(self.root, font=("Arial", 12), width=40)
        self.search_entry.pack(pady=5)
        self.search_entry.bind("<Return>", lambda event: self.search_user())

        # Кнопка поиска
        self.search_btn = tk.Button(self.root, text="🔍 Поиск", command=self.search_user, bg="#4CAF50", fg="white", font=("Arial", 10))
        self.search_btn.pack(pady=5)

        # Результаты поиска
        tk.Label(self.root, text="Результаты поиска:", font=("Arial", 10, "bold")).pack(pady=(20, 5))
        self.results_listbox = tk.Listbox(self.root, height=8, font=("Arial", 10))
        self.results_listbox.pack(fill=tk.BOTH, expand=True, padx=20, pady=5)
        self.results_listbox.bind("<Double-Button-1>", self.add_to_favorites_from_list)

        # Кнопка добавления в избранное
        self.add_btn = tk.Button(self.root, text="⭐ Добавить выбранного в избранное", command=self.add_selected_to_favorites, bg="#2196F3", fg="white")
        self.add_btn.pack(pady=5)

        # Список избранных
        tk.Label(self.root, text="Избранные пользователи:", font=("Arial", 10, "bold")).pack(pady=(20, 5))
        self.favorites_listbox = tk.Listbox(self.root, height=6, font=("Arial", 10))
        self.favorites_listbox.pack(fill=tk.BOTH, expand=True, padx=20, pady=5)
        self.favorites_listbox.bind("<Double-Button-1>", self.view_favorite_details)

        # Кнопка удаления из избранного
        self.remove_btn = tk.Button(self.root, text="❌ Удалить из избранного", command=self.remove_from_favorites, bg="#f44336", fg="white")
        self.remove_btn.pack(pady=5)

        # Обновить список избранных
        self.refresh_favorites_listbox()

    def load_favorites(self):
        """Загружает избранных из JSON"""
        if os.path.exists(self.favorites_file):
            with open(self.favorites_file, "r", encoding="utf-8") as f:
                return json.load(f)
        return []

    def save_favorites(self):
        """Сохраняет избранных в JSON"""
        with open(self.favorites_file, "w", encoding="utf-8") as f:
            json.dump(self.favorites, f, indent=4, ensure_ascii=False)

    def refresh_favorites_listbox(self):
        """Обновляет отображение избранных"""
        self.favorites_listbox.delete(0, tk.END)
        for fav in self.favorites:
            self.favorites_listbox.insert(tk.END, f"{fav['login']} — {fav['name'] or 'Нет имени'}")

    def search_user(self):
        """Поиск пользователя через GitHub API"""
        username = self.search_entry.get().strip()
        if not username:
            messagebox.showerror("Ошибка", "Поле поиска не может быть пустым.")
            return

        url = f"https://api.github.com/users/{username}"
        try:
            response = requests.get(url)
            if response.status_code == 200:
                user_data = response.json()
                self.results_listbox.delete(0, tk.END)
                self.results_listbox.insert(tk.END, f"Логин: {user_data['login']}")
                self.results_listbox.insert(tk.END, f"Имя: {user_data.get('name', 'Не указано')}")
                self.results_listbox.insert(tk.END, f"Публичные репозитории: {user_data['public_repos']}")
                self.results_listbox.insert(tk.END, f"Подписчики: {user_data['followers']}")
                self.results_listbox.insert(tk.END, f"Подписан: {user_data['following']}")
                self.results_listbox.insert(tk.END, f"Ссылка: {user_data['html_url']}")
                # Сохраняем данные для добавления в избранное
                self.last_search_data = user_data
            else:
                messagebox.showerror("Ошибка", f"Пользователь '{username}' не найден.")
                self.results_listbox.delete(0, tk.END)
        except requests.exceptions.RequestException as e:
            messagebox.showerror("Ошибка сети", f"Не удалось подключиться к API GitHub.\n{e}")

    def add_selected_to_favorites(self):
        """Добавляет пользователя из результата поиска в избранное"""
        if not hasattr(self, 'last_search_data'):
            messagebox.showwarning("Предупреждение", "Сначала выполните поиск пользователя.")
            return

        user = self.last_search_data
        # Проверяем, нет ли уже в избранном
        if any(fav['login'] == user['login'] for fav in self.favorites):
            messagebox.showinfo("Информация", f"{user['login']} уже в избранном.")
            return

        favorite = {
            "login": user['login'],
            "name": user.get('name'),
            "html_url": user['html_url'],
            "added_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        self.favorites.append(favorite)
        self.save_favorites()
        self.refresh_favorites_listbox()
        messagebox.showinfo("Успех", f"{user['login']} добавлен в избранное.")

    def add_to_favorites_from_list(self, event):
        """Добавление при двойном клике на результат поиска"""
        self.add_selected_to_favorites()

    def remove_from_favorites(self):
        """Удаляет выбранного из избранного"""
        selection = self.favorites_listbox.curselection()
        if not selection:
            messagebox.showwarning("Предупреждение", "Выберите пользователя для удаления.")
            return

        index = selection[0]
        removed = self.favorites.pop(index)
        self.save_favorites()
        self.refresh_favorites_listbox()
        messagebox.showinfo("Успех", f"{removed['login']} удалён из избранного.")

    def view_favorite_details(self, event):
        """Просмотр деталей избранного пользователя"""
        selection = self.favorites_listbox.curselection()
        if not selection:
            return
        index = selection[0]
        fav = self.favorites[index]
        details = f"Логин: {fav['login']}\nИмя: {fav['name'] or 'Не указано'}\nСсылка: {fav['html_url']}\nДобавлен: {fav['added_at']}"
        messagebox.showinfo("Информация о пользователе", details)

if __name__ == "__main__":
    root = tk.Tk()
    app = GitHubUserFinder(root)
    root.mainloop()
